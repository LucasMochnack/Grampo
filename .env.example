# -------------------------------------------------------
# Grampo — Zenvia Webhook Service  |  .env.example
# Copy this file to .env and adjust the values.
# -------------------------------------------------------

# --- Database ---
# Defaults to SQLite for local development (no server required).
# For production set a full PostgreSQL DSN:
#   postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./grampo_dev.db

# --- Webhook Security ---
# Secret token that Zenvia sends in the X-Zenvia-Token header
# (or Authorization: Bearer <token>).
# Leave empty to disable token validation — OK for local dev only.
WEBHOOK_SECRET_TOKEN=

# --- Application ---
APP_ENV=development
# LOG_LEVEL accepts: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
